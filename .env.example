# Ejemplo de variables de entorno para Novedades LZ Backend
# Copia este archivo como .env y reemplaza los valores con tus credenciales reales

# OCR.space API
# Obten tu API key gratuita en: https://ocr.space/ocrapi
OCR_SPACE_API_KEY=tu_api_key_de_ocr_space_aqui

# Cloudinary
# Obten tus credenciales en: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=tu_cloud_name_aqui
CLOUDINARY_API_KEY=tu_api_key_aqui
CLOUDINARY_API_SECRET=tu_api_secret_aqui
CLOUDINARY_URL=cloudinary://<your_api_key>:<your_api_secret>@<your_cloud_name>

# JWT Secret (cambiar en produccion)
# Generar uno aleatorio con: openssl rand -base64 64
JWT_SECRET=TuClaveSecretaSuperSeguraDeAlMenos64CaracteresParaHS512Algorithm

# Yape y panel admin
YAPE_RECIPIENT_NAME=Leslie Lopez
YAPE_RECIPIENT_PHONE=939662630
APP_ADMIN_ORDERS_URL=http://localhost:3000/admin/orders

# WhatsApp Cloud API (Meta)
# Requiere access token y phone number id del numero emisor configurado en Meta
WHATSAPP_NOTIFICATIONS_ENABLED=true
WHATSAPP_ADMIN_PHONE=+51939662630
WHATSAPP_PROVIDER=auto
WHATSAPP_CLOUD_API_ACCESS_TOKEN=tu_access_token_de_meta
WHATSAPP_CLOUD_API_PHONE_NUMBER_ID=tu_phone_number_id_de_meta
WHATSAPP_CLOUD_API_VERSION=v22.0

# Twilio Sandbox / Twilio WhatsApp
# Para pruebas locales puedes usar Account SID + Auth Token
# Para produccion Twilio recomienda API Key SID + API Key Secret
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=tu_auth_token_de_twilio
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Oracle Database (opcional, ya esta en application.properties)
# DB_URL=jdbc:oracle:thin:@//localhost:1521/XE
# DB_USERNAME=novedadeslz
# DB_PASSWORD=novedadeslz123
